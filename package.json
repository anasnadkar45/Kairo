{
  "name": "gmail-cal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "corsair:setup:integrations": "tsx src/scripts/setup-corsair-integrations.ts",
    "corsair:setup:tenant": "tsx src/scripts/setup-corsair-tenant.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@corsair-dev/cli": "^0.1.19",
    "@corsair-dev/gmail": "^0.1.4",
    "@corsair-dev/googlecalendar": "^0.1.4",
    "@prisma/client": "^6.6.0",
    "@t3-oss/env-nextjs": "latest",
    "better-auth": "^1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "corsair": "^0.1.76",
    "lucide-react": "^1.18.0",
    "next": "^15.2.3",
    "pg": "^8.21.0",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.6.0",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "npm@11.12.1"
}
